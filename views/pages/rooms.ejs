<% layout("layouts/boilerplate") %>
<link rel="stylesheet" href="/css/rooms.css">

<!-- HERO SECTION -->
<section class="hero-section d-flex align-items-center justify-content-center text-center text-white">
  <div class="overlay"></div>

  <div class="content">
    <h1 class="display-4 fw-bold hero-title">Find Your Perfect Room</h1>
    <p class="lead mb-3">Discover comfort, style and unforgettable stays tailored just for you.</p>

    <div class="mt-4">
      <a href="/" class="btn btn-danger btn-lg rounded-pill px-4 explore-btn">
        Explore Now
      </a>
    </div>

  </div>
</section>

<!-- FEATURED ROOMS -->
<section class="popular-section py-5">
  <div class="container">
    <h2 class="section-title text-center mb-5">Featured Rooms</h2>

    <div class="row g-4">

      <div class="col-lg-4 col-md-6 col-12">
        <div class="destination-card">
          <img src="/assets/goa-card.jpg" alt="Luxury Room">
          <div class="card-overlay">
            <h4>Luxury Rooms</h4>
            <p>Premium comfort & sea view</p>
          </div>
        </div>
      </div>

      <div class="col-lg-4 col-md-6 col-12">
        <div class="destination-card">
          <img src="/assets/manali-card.jpg" alt="Modern Stay">
          <div class="card-overlay">
            <h4>Modern Stay</h4>
            <p>Smart & stylish interiors</p>
          </div>
        </div>
      </div>

      <div class="col-lg-4 col-md-6 col-12">
        <div class="destination-card">
          <img src="/assets/jaipur-card.jpg" alt="Cozy Apartment">
          <div class="card-overlay">
            <h4>Cozy Apartment</h4>
            <p>Feel like home experience</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- WHY CHOOSE US SECTION -->
<section class="why-section py-5 bg-light">
  <div class="container text-center">
    <h2 class="mb-5">Why Choose Us?</h2>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="feature-box p-4">
          <h5>Affordable Prices</h5>
          <p>Best price guarantee with no hidden charges.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="feature-box p-4">
          <h5>24/7 Support</h5>
          <p>We are always here to help you anytime.</p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="feature-box p-4">
          <h5>Trusted Rooms</h5>
          <p>Verified listings for safe and secure stay.</p>
        </div>
      </div>
    </div>
  </div>
</section>
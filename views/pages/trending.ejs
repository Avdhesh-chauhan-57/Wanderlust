<section class="hero-section d-flex align-items-center justify-content-center text-center text-white ">
  <div class="overlay"></div>

  <div class="content">
    <h1 class="display-4 fw-bold price-text">Find Your Perfect Stay</h1>
    <p class="lead ">Discover amazing places at exclusive deals.</p>
    <div class="mt-4">
      <a href="/" class="btn btn-danger btn-md me-3">Explore Now</a>
      <a href="/listings/new" class="btn btn-light btn-md">Add Listing</a>
    </div>
  </div>
</section>

